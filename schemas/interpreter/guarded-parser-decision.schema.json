{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://manurella.dev/schemas/interpreter/guarded-parser-decision.v0.json",
  "title": "Manurella Guarded Parser Decision",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "adapter_version", "mode", "disposition", "selected_parser", "promotion", "candidate", "selected_task_frame"],
  "properties": {
    "schema_version": { "const": "guarded-parser-decision.v0" },
    "adapter_version": { "const": "guarded-model-inference.v0" },
    "mode": { "const": "guarded" },
    "disposition": { "enum": ["candidate_selected", "fallback_promotion", "fallback_validation"] },
    "selected_parser": { "enum": ["model-inference-compiler", "deterministic-rule-baseline"] },
    "promotion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["result_ref", "status", "identity_match"],
      "properties": {
        "result_ref": { "type": "string", "minLength": 1 },
        "status": { "enum": ["pass", "fail"] },
        "identity_match": { "type": "boolean" }
      }
    },
    "candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["model", "prompt_version", "would_be_eligible", "schema_valid", "trust_aligned", "semantic_valid", "routing_valid", "issues"],
      "properties": {
        "model": { "type": ["string", "null"] },
        "prompt_version": { "type": ["string", "null"] },
        "would_be_eligible": { "type": "boolean" },
        "schema_valid": { "type": "boolean" },
        "trust_aligned": { "type": "boolean" },
        "semantic_valid": { "type": "boolean" },
        "routing_valid": { "type": "boolean" },
        "issues": { "type": "array", "items": { "type": "string" } }
      }
    },
    "selected_task_frame": { "type": "object" }
  },
  "allOf": [
    {
      "if": { "properties": { "disposition": { "const": "candidate_selected" } } },
      "then": {
        "properties": {
          "selected_parser": { "const": "model-inference-compiler" },
          "promotion": {
            "properties": { "status": { "const": "pass" }, "identity_match": { "const": true } }
          },
          "candidate": { "properties": { "would_be_eligible": { "const": true } } }
        }
      }
    },
    {
      "if": { "properties": { "disposition": { "enum": ["fallback_promotion", "fallback_validation"] } } },
      "then": { "properties": { "selected_parser": { "const": "deterministic-rule-baseline" } } }
    }
  ]
}
