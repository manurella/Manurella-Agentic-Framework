{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://manurella.dev/schemas/runtime/execution-observation-bundle.v0.json",
  "title": "Manurella Runtime Execution Observation Bundle",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "bundle_id", "captured_at", "adapter", "lineage", "source_capture", "privacy", "observations", "recovery"],
  "properties": {
    "schema_version": { "const": "execution-observation-bundle.v0" },
    "bundle_id": { "type": "string", "minLength": 1 },
    "captured_at": { "type": "string", "format": "date-time" },
    "adapter": { "type": "string", "pattern": "^[a-z][a-z0-9_-]*$" },
    "lineage": {
      "type": "object", "additionalProperties": false,
      "required": ["session_id", "packet_id", "projection_id"],
      "properties": {
        "session_id": { "type": "string", "minLength": 1 },
        "packet_id": { "type": "string", "minLength": 1 },
        "projection_id": { "type": "string", "minLength": 1 }
      }
    },
    "source_capture": {
      "type": "object", "additionalProperties": false,
      "required": ["capture_id", "capture_trust", "invocation_status", "timeout_status", "exit_code", "event_count", "raw_events_sha256", "model_output_sha256"],
      "properties": {
        "capture_id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,159}$" },
        "capture_trust": { "enum": ["unverified", "trusted_runtime"] },
        "invocation_status": { "enum": ["completed", "failed", "timeout", "cancelled", "policy_blocked", "unknown"] },
        "timeout_status": { "enum": ["none", "upstream_idle_timeout", "user_stopped", "unknown"] },
        "exit_code": { "type": ["integer", "null"] },
        "event_count": { "type": "integer", "minimum": 0 },
        "raw_events_sha256": { "$ref": "#/$defs/nullableDigest" },
        "model_output_sha256": { "$ref": "#/$defs/nullableDigest" }
      }
    },
    "privacy": {
      "type": "object", "additionalProperties": false,
      "required": ["raw_event_payload_embedded", "model_output_embedded", "digest_only"],
      "properties": {
        "raw_event_payload_embedded": { "const": false },
        "model_output_embedded": { "const": false },
        "digest_only": { "const": true }
      }
    },
    "observations": {
      "type": "array", "minItems": 1, "maxItems": 1,
      "items": { "$ref": "https://manurella.dev/schemas/brain/observation-event.v0.json" }
    },
    "recovery": {
      "type": "object", "additionalProperties": false,
      "required": ["required", "reason", "checkpoint_ref", "prior_packet_ref", "preserved_artifact_refs"],
      "properties": {
        "required": { "type": "boolean" },
        "reason": { "enum": ["none", "upstream_idle_timeout", "user_stopped", "runtime_status_unknown"] },
        "checkpoint_ref": { "type": "string", "minLength": 1 },
        "prior_packet_ref": { "type": "string", "minLength": 1 },
        "preserved_artifact_refs": { "$ref": "#/$defs/refArray" }
      }
    }
  },
  "$defs": {
    "digest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "nullableDigest": { "oneOf": [{ "$ref": "#/$defs/digest" }, { "type": "null" }] },
    "stringArray": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
    "refArray": { "type": "array", "items": { "type": "string", "pattern": "^[a-z][a-z0-9+.-]*://\\S{1,480}$" }, "uniqueItems": true }
  }
}
