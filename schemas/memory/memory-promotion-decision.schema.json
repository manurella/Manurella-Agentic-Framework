{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://manurella.dev/schemas/memory/memory-promotion-decision.v0.json",
  "title": "Manurella Memory Promotion Decision",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "decision_id", "proposal_ref", "disposition", "target_store", "reason_codes", "detected_conflict_refs", "record"],
  "properties": {
    "schema_version": { "const": "memory-promotion-decision.v0" },
    "decision_id": { "type": "string", "minLength": 1 },
    "proposal_ref": { "type": "string", "minLength": 1 },
    "disposition": { "enum": ["quarantine", "retain_episodic", "pending_review", "promote_durable", "reject"] },
    "target_store": { "enum": ["none", "episodic", "semantic", "procedural", "project", "atlas"] },
    "reason_codes": {
      "type": "array", "minItems": 1, "uniqueItems": true,
      "items": { "enum": ["untrusted_source", "source_authority_mismatch", "session_retention", "write_permission_missing", "human_review_pending", "human_review_failed", "contradiction_unresolved", "invalid_supersession_ref", "benchmark_evidence_missing", "repeated_support_missing", "promotion_requirements_met"] }
    },
    "detected_conflict_refs": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
    "record": { "oneOf": [{ "$ref": "memory-record.v0.json" }, { "type": "null" }] }
  },
  "allOf": [
    {
      "if": { "properties": { "disposition": { "const": "retain_episodic" } }, "required": ["disposition"] },
      "then": {
        "properties": {
          "target_store": { "const": "episodic" },
          "record": {
            "allOf": [
              { "$ref": "memory-record.v0.json" },
              { "properties": { "memory_type": { "const": "episodic" }, "lifecycle": { "const": "candidate" } } }
            ]
          }
        }
      }
    },
    {
      "if": { "properties": { "disposition": { "const": "promote_durable" } }, "required": ["disposition"] },
      "then": {
        "properties": {
          "target_store": { "enum": ["semantic", "procedural", "project", "atlas"] },
          "record": { "allOf": [{ "$ref": "memory-record.v0.json" }, { "properties": { "lifecycle": { "const": "active" } } }] }
        }
      }
    },
    {
      "if": { "properties": { "target_store": { "const": "semantic" } }, "required": ["target_store"] },
      "then": { "properties": { "record": { "properties": { "memory_type": { "enum": ["semantic", "user_preference"] } } } } }
    },
    {
      "if": { "properties": { "target_store": { "const": "procedural" } }, "required": ["target_store"] },
      "then": { "properties": { "record": { "properties": { "memory_type": { "enum": ["procedural", "failure_lesson"] } } } } }
    },
    {
      "if": { "properties": { "target_store": { "const": "project" } }, "required": ["target_store"] },
      "then": {
        "properties": {
          "record": { "properties": { "memory_type": { "const": "project_state" } } }
        }
      }
    },
    {
      "if": { "properties": { "target_store": { "const": "atlas" } }, "required": ["target_store"] },
      "then": {
        "properties": {
          "record": { "properties": { "memory_type": { "const": "atlas_mutation" } } }
        }
      }
    },
    {
      "if": { "properties": { "disposition": { "enum": ["quarantine", "pending_review", "reject"] } }, "required": ["disposition"] },
      "then": { "properties": { "target_store": { "const": "none" }, "record": { "type": "null" } } }
    }
  ]
}
