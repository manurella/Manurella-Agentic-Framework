{
  "$schema": "https://json-schema.org/draft/2020/schema",
  "$id": "https://manurella.dev/schemas/evals/parser-promotion-result.schema.json",
  "title": "Manurella Parser Repeated-Run Promotion Result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "promotion_id",
    "created_at",
    "model",
    "prompt_version",
    "minimum_runs",
    "runs",
    "summary",
    "promotion"
  ],
  "properties": {
    "schema_version": { "const": "parser-promotion-result.v0" },
    "promotion_id": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "format": "date-time" },
    "model": { "type": "string", "minLength": 1 },
    "prompt_version": { "type": "string", "minLength": 1 },
    "minimum_runs": { "type": "integer", "minimum": 2 },
    "runs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "run_id",
          "result_ref",
          "status",
          "schema_valid_rate",
          "semantic_valid_rate",
          "routing_valid_rate",
          "critical_field_accuracy",
          "safety_pass_rate"
        ],
        "properties": {
          "run_id": { "type": "string", "minLength": 1 },
          "result_ref": { "type": "string", "minLength": 1 },
          "status": { "enum": ["pass", "fail"] },
          "schema_valid_rate": { "type": "number", "minimum": 0, "maximum": 1 },
          "semantic_valid_rate": { "type": "number", "minimum": 0, "maximum": 1 },
          "routing_valid_rate": { "type": "number", "minimum": 0, "maximum": 1 },
          "critical_field_accuracy": { "type": "number", "minimum": 0, "maximum": 1 },
          "safety_pass_rate": { "type": "number", "minimum": 0, "maximum": 1 }
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "runs_total",
        "runs_passed",
        "pass_rate",
        "minimum_critical_field_accuracy",
        "minimum_safety_pass_rate",
        "minimum_semantic_valid_rate",
        "minimum_routing_valid_rate"
      ],
      "properties": {
        "runs_total": { "type": "integer", "minimum": 1 },
        "runs_passed": { "type": "integer", "minimum": 0 },
        "pass_rate": { "type": "number", "minimum": 0, "maximum": 1 },
        "minimum_critical_field_accuracy": { "type": "number", "minimum": 0, "maximum": 1 },
        "minimum_safety_pass_rate": { "type": "number", "minimum": 0, "maximum": 1 },
        "minimum_semantic_valid_rate": { "type": "number", "minimum": 0, "maximum": 1 },
        "minimum_routing_valid_rate": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "promotion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "reasons"],
      "properties": {
        "status": { "enum": ["pass", "fail"] },
        "reasons": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
