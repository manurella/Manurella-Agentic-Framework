{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://manurella.dev/schemas/evals/guarded-parser-observation-result.schema.json",
  "title": "Manurella Guarded Parser Observation Result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "observation_id",
    "evidence_class",
    "promotion_ref",
    "candidate_run_refs",
    "observations",
    "summary",
    "activation"
  ],
  "properties": {
    "schema_version": { "const": "guarded-parser-observation-result.v0" },
    "observation_id": { "type": "string", "minLength": 1 },
    "evidence_class": { "const": "representative_replay" },
    "promotion_ref": { "type": "string", "minLength": 1 },
    "candidate_run_refs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "observations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "run_id",
          "case_id",
          "disposition",
          "selected_parser",
          "identity_match",
          "schema_valid",
          "trust_aligned",
          "semantic_valid",
          "routing_valid",
          "issues"
        ],
        "properties": {
          "run_id": { "type": "string", "minLength": 1 },
          "case_id": { "type": "string", "minLength": 1 },
          "disposition": {
            "enum": ["candidate_selected", "fallback_promotion", "fallback_validation"]
          },
          "selected_parser": {
            "enum": ["model-inference-compiler", "deterministic-rule-baseline"]
          },
          "identity_match": { "type": "boolean" },
          "schema_valid": { "type": "boolean" },
          "trust_aligned": { "type": "boolean" },
          "semantic_valid": { "type": "boolean" },
          "routing_valid": { "type": "boolean" },
          "issues": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "runs_total",
        "requests_total",
        "candidate_selected",
        "fallback_promotion",
        "fallback_validation",
        "selection_rate"
      ],
      "properties": {
        "runs_total": { "type": "integer", "minimum": 1 },
        "requests_total": { "type": "integer", "minimum": 1 },
        "candidate_selected": { "type": "integer", "minimum": 0 },
        "fallback_promotion": { "type": "integer", "minimum": 0 },
        "fallback_validation": { "type": "integer", "minimum": 0 },
        "selection_rate": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "activation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "default_mode", "reasons"],
      "properties": {
        "status": { "const": "insufficient_live_evidence" },
        "default_mode": { "const": "shadow" },
        "reasons": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
